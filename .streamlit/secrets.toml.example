# Arquivo de exemplo para configuração de secrets no Streamlit Cloud
#
# Como usar:
#   1. Acesse seu app em share.streamlit.io
#   2. Clique em "Settings" → "Secrets"
#   3. Cole o conteúdo abaixo substituindo o valor pela URL real
#
# Para rodar localmente, copie este arquivo como .streamlit/secrets.toml
# e preencha com sua URL real (mas NÃO suba esse arquivo para o GitHub).

POSTGRES_URL = "postgresql://usuario:senha@host.supabase.co:5432/postgres"
